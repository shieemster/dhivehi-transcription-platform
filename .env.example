# --- Required (no fallback — services will fail or refuse to start without these) ---

# 32-byte AES-256 key, base64-encoded, used for MinIO SSE-C encryption at
# rest. Generate with: openssl rand -base64 32
SSE_C_KEY=

# HuggingFace access token — gradio_diarization crashes on startup without
# this (needed to download the pyannote speaker-diarization model).
HUGGINGFACE_ACCESS_TOKEN=

# Gemini API key — powers the analysis step (translation/entities/summary)
# and real segment embeddings in gradio_transcription. If unset, embeddings
# silently fall back to a zero vector rather than crashing (see
# transcription.py's generate_embedding).
GEMINI_API_KEY=

# --- Required for email verification / forgot-password to actually deliver mail ---
# (the rest of the app still runs fine without these — SendEmail just fails
# with a clear error at call time until they're set)

# SMTP relay for verification codes and password-reset codes. Works with any
# standard SMTP-AUTH provider. Two common examples:
#
#   Gmail (requires a Google Account App Password, not your normal password —
#   generate one at https://myaccount.google.com/apppasswords, only available
#   with 2-Step Verification turned on):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USERNAME=youraddress@gmail.com
#     SMTP_PASSWORD=<16-character app password>
#     SMTP_FROM=youraddress@gmail.com
#
#   SendGrid (SMTP relay, API key as the password):
#     SMTP_HOST=smtp.sendgrid.net
#     SMTP_PORT=587
#     SMTP_USERNAME=apikey
#     SMTP_PASSWORD=<your SendGrid API key>
#     SMTP_FROM=verified-sender@yourdomain.com
#
# Port 465 is dialed with implicit TLS; anything else (587, 25) negotiates
# STARTTLS.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- Optional (safe dev defaults in compose.yml, override for anything beyond local dev) ---

# Postgres password for the transcript_app user. Default: changeme_dev_only
POSTGRES_PASSWORD=

# HMAC secret signing JWTs. Default: dev_only_insecure_secret_change_me
# Rotating this invalidates every existing session immediately.
JWT_SECRET=

# Origin the backend's CORS policy allows. Default: https://localhost:3443
# (the Caddy-fronted frontend). Only needs overriding if you change ports
# or deploy somewhere other than localhost.
FRONTEND_ORIGIN=
